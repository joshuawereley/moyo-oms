        <mxCell id="1AXi3KVPrKXrGz5YjfVP-64" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontColor=light-dark(#000000,#ABABAB);" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Notes&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Assumed that Vendor should be modelled as an external B2B partner.&lt;/li&gt;&lt;li&gt;Payment authorised at Client Portal checkout, prior to order reaching Order Management System.&lt;/li&gt;&lt;li&gt;Identity strategy is segmented by audience; Entra External ID (B2B) for Vendors, Entra External ID (CIAM) for Clients, Entra ID workforce tenant for internal staff. Chosen in part for free-tier viability at the assumed enterprise scale.&lt;/li&gt;&lt;li&gt;Payment Gateway is architecturally scoped only; no implementation is included.&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="200" width="410" x="250" y="760" as="geometry" />
        </mxCell>
